    {
      "id": "047e7cca-b165-4a5e-9421-74241d26ce70",
      "type": "embed://a2/generate.bgl.json#module:main",
      "metadata": {
        "title": "Generate Food Order",
        "visual": {
          "x": 800,
          "y": 440
        },
        "userModified": true,
        "expected_output": [
          {
            "description": "Generated text of a food order with pickup details",
            "type": "text",
            "list": false
          }
        ]
      },
      "configuration": {
        "config$prompt": {
          "role": "user",
          "parts": [
            {
              "text": "I want to a organize a system of food orders from restaurants within a 10 minute walk of the Harvard T.H. Chan School of Public Health (677 Huntington Avenue, Boston, MA 02115). \n\nThe app should find a restaurant for the relevant {{\"type\":\"in\",\"path\":\"1eb15dfa-508d-46f3-95f3-6dd21427a13f\",\"title\":\"Meal type\"}}. If there are multiple dates in {{\"type\":\"in\",\"path\":\"ask_user_talk_date\",\"title\":\"Talk Date\"}}, I want each date to have food from a different restaurant (ideally with different genres of food) so it doesn't get repetitive. Find ones with good ratings; if it has less than a 3 rating in google reviews it shouldn't be included. \n\nThe app should find a restaurant in the area and generate an order based on the menu that will serve the number of people that is specified by {{\"type\":\"in\",\"path\":\"ask_user_attendee_count\",\"title\":\"Attendee Count\"}}. The order total with 20% tip should not exceed the budget cost by {{\"type\":\"in\",\"path\":\"83d98265-aebc-43be-809c-158c5d015d6c\",\"title\":\"Per person budget\"}}for each attendee. The order should be detailed. For example, don't just say \"variety of pizzas\", find a specific set of pizzas that have variety. \n\nOutput the menu information for each meeting (including each item with the cost and quantity), along with the information for the person responsible for ordering the food for that meeting with is done in. The URLs should be live and active. \n"
            }
          ]
        },
        "generation-mode": "agent"
      }
    },
    {
      "id": "83d98265-aebc-43be-809c-158c5d015d6c",
      "type": "embed://a2/a2.bgl.json#21ee02e7-83fa-49d0-964c-0cab10eafc2c",
      "metadata": {
        "title": "Per person budget",
        "visual": {
          "x": 240,
          "y": 1100
        },
        "userModified": true
      },
      "configuration": {
        "description": {
          "role": "user",
          "parts": [
            {
              "text": "What is the price per person you're willing to spend? (Default is $10 pp for lunch/dinner, $5 pp for breakfast)"
            }
          ]
        },
        "p-modality": "Any",
        "p-required": false
      }
    },
    {
      "id": "abeebeb8-2f7c-40b0-b7b9-0775e9537812",
