        "p-modality": "Any",
        "p-required": false
      }
    },
    {
      "id": "acb0ddb0-473e-42b1-88db-3bca307b6b3e",
      "type": "embed://a2/generate.bgl.json#module:main",
      "metadata": {
        "title": "Generate pickup scheduling",
        "visual": {
          "x": 900,
          "y": 860
        },
        "userModified": true
      },
      "configuration": {
        "config$prompt": {
          "role": "user",
          "parts": [
            {
              "text": "{{\"type\":\"in\",\"path\":\"047e7cca-b165-4a5e-9421-74241d26ce70\",\"title\":\"Generate Food Order\"}} {{\"type\":\"in\",\"path\":\"ask_user_pickup_time\",\"title\":\"Pickup Time\"}} {{\"type\":\"in\",\"path\":\"ask_user_event_name\",\"title\":\"Meeting Name\"}}\n\nRandomly pick one of the email addresses from the {{\"type\":\"in\",\"path\":\"abeebeb8-2f7c-40b0-b7b9-0775e9537812\",\"title\":\"Pickup people\"}}list and assign them to be responsible for placing and picking up the order.  Cycle through the people so that the same person isn't picking up the order week after week \n\nDraft 2 emails for each order. One is for the day before which should be sent at 9 AM and tells the person assigned to the order all the information about what they need to get (price information, quantity of items, the URL to the restaurant, etc.) Then another is a reminder email that will be sent 4 hours before the meeting.\n\nThese emails should be displayed in the final HTML and in the  Google sheet that is generated.\n"
            }
          ]
        },
        "generation-mode": "agent"
      }
    },
